# Copy to .env.local for local development (not committed).
# Vercel: set REACT_APP_API_URL in Project → Environment Variables.
# Use the API origin only (no trailing slash, no /api suffix). Example:
#   https://your-service.onrender.com
# If you mistakenly add /api, it is stripped so paths stay /api/... not /api/api/...
REACT_APP_API_URL=http://localhost:8000

# ─── Contact form (EmailJS) ─────────────────────────────────────────────────
# Create React App only exposes variables prefixed with REACT_APP_ to the browser.
# ADMIN_CONTACT_MAIL is represented as REACT_APP_ADMIN_CONTACT_MAIL below.
REACT_APP_EMAILJS_PUBLIC_KEY=
REACT_APP_EMAILJS_SERVICE_ID=
REACT_APP_EMAILJS_TEMPLATE_ID=
REACT_APP_ADMIN_CONTACT_MAIL=admin@example.com
