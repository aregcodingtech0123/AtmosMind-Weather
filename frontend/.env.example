# Copy to .env.local for local development (not committed).
# Vercel: set REACT_APP_API_URL in Project → Environment Variables.
# Use the API origin only (no trailing slash, no /api suffix). Example:
#   https://your-service.onrender.com
# If you mistakenly add /api, it is stripped so paths stay /api/... not /api/api/...
REACT_APP_API_URL=http://localhost:8000
