# Copy this file to .env and fill in your values. Do not commit .env.

# Set to "production" to disable FastAPI /docs, /redoc, and /openapi.json
# ENV=development

# Required for AI Weather Assistant (Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Optional: defaults shown
REDIS_PASSWORD=change_this_to_a_long_random_password
REDIS_URL=redis://:change_this_to_a_long_random_password@redis:6379
# Comma-separated browser origins allowed to call the API (CORS)
# ALLOWED_ORIGINS=https://atmosmindweather.com,http://localhost:3000
# Set true only when a trusted reverse proxy sets X-Forwarded-For
# TRUSTED_PROXY=false
# LangChain chat memory (optional — sliding window per session)
# CHAT_MEMORY_WINDOW_K=10
# CHAT_SESSION_TTL_SECONDS=86400
# DATABASE_PATH=./cities.db
DATABASE_PATH=/app/data/cities.db
# Open-Meteo outbound throttling (prevents 429 rate limits on startup / batch)
# PREWARM_CITIES_LIMIT=80
# OPEN_METEO_BATCH_CHUNK_SIZE=40
# OPEN_METEO_CHUNK_PAUSE_SECONDS=1.5
# City detail forecast (Open-Meteo can be slow from cloud hosts; default read timeout 35s)
# WEATHER_DETAIL_READ_TIMEOUT_SECONDS=35
# WEATHER_DETAIL_CONNECT_TIMEOUT_SECONDS=8
# WEATHER_DETAIL_MAX_RETRIES=4
# Structured logging (JSON when ENV=production) and LangSmith tracing
# ENV=production
# LOG_LEVEL=INFO
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key
# LANGCHAIN_PROJECT=atmosmind-agent
